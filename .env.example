# Database
# Local dev: Docker postgres (used by pnpm db:up)
DATABASE_URL="postgresql://postgres:password@localhost:5432/finmate"
# Same as DATABASE_URL for local dev. On Supabase: use direct connection (port 5432) here.
DIRECT_URL="postgresql://postgres:password@localhost:5432/finmate"

# Supabase production:
# DATABASE_URL  → pooled connection  (Settings → Database → Transaction mode, port 6543)
# DIRECT_URL    → direct connection  (Settings → Database → Direct connection, port 5432)
# DATABASE_URL="postgresql://postgres.xxxx:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres"
# DIRECT_URL="postgresql://postgres:[PASSWORD]@db.xxxx.supabase.co:5432/postgres"

# OpenRouter API Key for Traders Arena
# Get your key from: https://openrouter.ai/keys
OPENROUTER_API_KEY=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

# Redis (for Traders Arena)
REDIS_URL="redis://localhost:6379"

# Frontend URL
FRONTEND_URL="http://localhost:3000"
APP_URL="http://localhost:3000"

# HuggingFace Inference API (sentiment + embeddings)
HUGGINGFACE_API_KEY=hf_your_key_here

# Groq (LLM summarization + tag extraction)
GROQ_API_KEY=gsk_your_key_here

# ---- FundLens ----
# All fundlens-* services read FUNDLENS_-prefixed env vars.
# In local dev these default to the same Docker postgres + redis as the rest of the monorepo.
FUNDLENS_DATABASE_URL="postgresql://postgres:password@localhost:5432/finmate"
FUNDLENS_REDIS_URL="redis://localhost:6379/0"
FUNDLENS_FRONTEND_URL="http://localhost:3000"
FUNDLENS_LOG_LEVEL="INFO"
FUNDLENS_API_PORT="5000"
FUNDLENS_HTTP_PORT="8001"
FUNDLENS_RATE_LIMIT_PER_MIN="100"

# Frontend → Go API: set this so /fundlens-api/* in Next.js proxies to the right host.
# In docker-compose this is internal; in dev it's localhost; in prod it's the public URL.
NEXT_PUBLIC_FUNDLENS_API_URL="http://localhost:5000"
