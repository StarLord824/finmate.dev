{
  "manifest_version": 3,
  "name": "FinMate Pulse",
  "version": "1.0.0",
  "description": "Your ultimate financial companion.",
  "action": {
    "default_popup": "index.html"
  },
  "permissions": [
    "storage",
    "cookies",
    "activeTab",
    "contextMenus"
  ],
  "host_permissions": [
    "http://localhost:3000/*",
    "https://finmate-dev.vercel.app/*"
  ],
  "background": {
    "service_worker": "src/background/index.ts",
    "type": "module"
  }
}
